# /etc/systemd/system/agrodrone-mission-upload.service
[Unit]
Description=AgroDrone Mission Upload to FC
After=network.target

[Service]
Type=simple
User=sr-design
WorkingDirectory=/home/sr-design/EC463_Team_17_AgroDrone/uart
Environment="AGRO_OUTDIR=/home/sr-design/export"
ExecStart=/home/sr-design/.local/bin/uv run MissionUploader.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

